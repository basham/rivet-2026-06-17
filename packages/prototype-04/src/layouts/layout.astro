---
import "@rivet-iu/core/dist/rivet.css";
import "@rivet-iu/core/dist/rivet-icons.css";
import "@rivet-iu/core/dist/rivet-stickers.css";
import Footer from "@rivet-iu/core/src/components/footer/footer.astro";
import Header from "../components/header.astro";
import { menus as _menus, site } from "../const.js";
import { getMenus, getUrl } from "../util.js";

const menus = getMenus(_menus, Astro);
const { label: title } = menus.page;
const root = Astro.url.pathname === getUrl() + "/";
const docTitle = root ? site : [title, site].join(" - ");
const hideTitle = Astro.slots.has("default");
const breadcrumbs = [];

if (menus.page) {
	let parent = menus.page.getParent();
	while (parent) {
		breadcrumbs.unshift(parent);
		parent = parent.getParent();
	}
}

const menu = menus.page.hasChildren ? menus.page : menus.page.getParent();
const menuParent = menu.getParent();

const topMenus = getMenus(_menus, { url: { pathname: "/" } });
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{docTitle}</title>
	</head>
	<body>
		<Header menus={topMenus} />
		<div class="layout">
			{
				!root && menu.parent && (
					<rvt-prototype-section-nav>
						<button
							class="rvt-button rvt-button--small"
							popovertarget="rvt-section-nav"
						>
							In this section
							<rvt-icon name="chevron-down"></rvt-icon>
						</button>
						<nav
							aria-label="Section nav"
							id="rvt-section-nav"
							popover
						>
							{menuParent.id !== "main" && (
								<a href={menuParent.url}>
									<rvt-icon name="arrow-left"></rvt-icon>
									{menuParent.label}
								</a>
							)}
							<ul>
								{menu.parent.items.map((item: any, i: number) => (
									<li>
										<a
											aria-current={item.current ? "page" : null}
											href={item.url}
										>
											{item.label}
										</a>
									</li>
								))}
							</ul>
						</nav>
					</rvt-prototype-section-nav>
				)
			}
			{
				!root && (
					<rvt-breadcrumbs>
						<nav aria-label="Breadcrumbs">
							<ol class="rvt-breadcrumbs">
								{breadcrumbs.map((item, i) => (
									<li>
										<a href={item.url}>
											{i === 0 && <span class="rvt-sr-only">Home</span>}
											{i > 0 && item.label}
										</a>
									</li>
								))}
								<li aria-current="page">{title}</li>
							</ol>
						</nav>
					</rvt-breadcrumbs>
				)
			}
			<main id="main-content">
				{
					!hideTitle && (
						<div class="rvt-hero">
							<div class="rvt-hero__body">
								<h1 class="rvt-hero__title">Highlights in {title}</h1>
							</div>
						</div>
					)
				}
				{hideTitle && <h1 class="rvt-sr-only">{title}</h1>}
				{
					menus.page?.articles && (
						<div class="content">
							{menus.page.articles.map((article: any) => (
								<>
									<h2>{article.label}</h2>
									<p>{article.description}</p>
								</>
							))}
						</div>
					)
				}
				<slot />
				{
					menus.page.items && (
						<div>
							<ul class="rvt-card-grid rvt-m-tb-none">
								{menus.page.items.map((item: any) => (
									<li>
										<div class="rvt-card">
											<div class="rvt-card__body">
												<h2 class="rvt-card__title">
													<a href={item.url}>{item.label}</a>
												</h2>
												{item.articles && (
													<div class="rvt-card__content">
														{item.articles.map((article: any) => (
															<p>{article.label}</p>
														))}
													</div>
												)}
											</div>
										</div>
									</li>
								))}
							</ul>
						</div>
					)
				}
			</main>
			{
				!root && (
					<aside>
						<rvt-prototype-related-nav>
							<nav aria-labelledby="rvt-prototype-related-nav-heading">
								<h2 id="rvt-prototype-related-nav-heading">
									Related
								</h2>
								<ul>
									{menu.items.map((item: any) => (
										<li>
											<a
												aria-current={item.current ? "page" : null}
												href={item.url || "#"}
											>
												{item.label}
											</a>
										</li>
									))}
								</ul>
							</nav>
						</rvt-prototype-related-nav>
					</aside>
				)
			}
		</div>
		<Footer />
	</body>
</html>

<style is:global>
	:is(rvt-header, .rvt-footer) .rvt-container {
		max-width: unset;
		padding-inline: var(--rvt-size-24);
	}
</style>

<style>
	.layout {
		display: grid;
		grid-template-areas:
			"section-nav breadcrumbs"
			"main main"
			"aside aside";
		grid-template-columns: auto 1fr;
		grid-template-rows: auto auto auto;
	}

	rvt-prototype-section-nav {
		display: block;
		grid-area: section-nav;
		padding-inline: var(--rvt-size-24);

		nav {
			h2 {
				font: var(--rvt-font-18-bold);
				margin-block-end: var(--rvt-size-16);
			}

			a {
				color: unset;
				display: block;
				font: var(--rvt-font-18);
				text-decoration: none;

				&:visited {
					color: inherit;
				}

				&:hover {
					color: var(--rvt-color-theme-text-accent);
					text-decoration: underline;
				}

				&[aria-current="page"] {
					color: var(--rvt-color-theme-text-accent);
					font-variation-settings: var(--rvt-font-variation-grade);
					text-decoration: underline;
					text-underline-offset: var(--rvt-size-4);
				}
			}

			> a {
				align-items: center;
				display: flex;
				font: var(--rvt-font-18-bold);
				gap: var(--rvt-size-8);
			}

			ul {
				list-style-type: "";
				margin: 0;
				padding: 0;

				&:not(:first-child) {
					margin-block-start: var(--rvt-size-16);
				}

				li:not(:first-child) {
					margin-block-start: var(--rvt-size-8);
				}
			}
		}
	}

	rvt-breadcrumbs {
		align-self: center;
		display: block;
		grid-area: breadcrumbs;

		nav {
			display: flex;
		}
	}

	main {
		grid-area: main;
		padding: var(--rvt-size-24);

		.rvt-hero {
			margin-block-end: var(--rvt-size-24);
			margin-inline: unset;
			padding-inline: 0;
		}

		.content {
			h2 {
				font: var(--rvt-font-20-fluid-black);
				margin-block-start: var(--rvt-size-32);
			}
		}

		.rvt-card-grid {
			--gap: clamp(var(--rvt-size-16), 5vw, var(--rvt-size-40));
			grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
		}
	}

	aside {
		background-color: var(--rvt-color-theme-background-strong);
		border-block-start: var(--rvt-border);
		grid-area: aside;
		padding: var(--rvt-size-24);
	}

	rvt-prototype-related-nav {
		background-color: var(--rvt-color-theme-background);
		border: var(--rvt-border);
		display: block;
		padding: var(--rvt-size-24);

		nav {
			h2 {
				font: var(--rvt-font-16-bold);
			}

			ul {
				list-style-type: "";
				margin: 0;
				padding: 0;

				li {
					margin-block-start: var(--rvt-size-8);
				}

				a {
					color: unset;
					display: block;
					font: var(--rvt-font-14);
					text-decoration: none;

					&:visited {
						color: inherit;
					}

					&:hover {
						color: var(--rvt-color-theme-text-accent);
						text-decoration: underline;
					}

					&[aria-current="page"] {
						color: var(--rvt-color-theme-text-accent);
						font: inherit;
						font-variation-settings: var(--rvt-font-variation-grade);
						text-decoration: underline;
						text-underline-offset: var(--rvt-size-4);
					}
				}
			}
		}
	}

	@media (width > 50rem) {
		.layout:has(aside) {
			display: grid;
			border-block-start: var(--rvt-border);
			grid-template-areas:
				"section-nav breadcrumbs"
				"section-nav main"
				"section-nav aside";
			grid-template-columns: min(30vw, 18rem) 1fr;
			grid-template-rows: auto auto 1fr;

			rvt-prototype-section-nav {
				border-inline-end: var(--rvt-border);
				padding: var(--rvt-size-24);

				button[popovertarget] {
					display: none;
				}
			}

			rvt-breadcrumbs {
				padding-block-start: var(--rvt-size-24);
				padding-inline: var(--rvt-size-24);
			}
		}
	}

	@media (width > 80rem) {
		.layout:has(aside) {
			display: grid;
			border-block-start: var(--rvt-border);
			grid-template-areas:
				"section-nav breadcrumbs aside"
				"section-nav main aside";
			grid-template-columns: 18rem 1fr 18rem;
			grid-template-rows: auto 1fr;

			:is(rvt-breadcrumbs, main) {
				justify-self: center;
				max-width: 80rem;
				width: 100%;
			}

			aside {
				border-block-start: none;
				border-inline-start: var(--rvt-border);
				display: block;
			}
		}
	}
</style>

<script>
	import "@rivet-iu/core";
</script>

<script>
	const popover = document.getElementById("rvt-section-nav");
	if (popover) {
		popover.addEventListener('beforetoggle', (event) => {
			if (event.newState === 'open') {
				requestAnimationFrame(() => {
					const firstFocusable = popover.querySelector('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])') as HTMLElement;
					if (firstFocusable) {
						firstFocusable.focus();
					} else {
						popover.focus();
					}
				});
			}
		});

		popover.addEventListener("focusout", (event) => {
			if (!popover.contains(event.relatedTarget as Node)) {
				popover.hidePopover();
			}
		});

		const mq = window.matchMedia("(width > 50rem)");

		function handleViewportChange(matches: Boolean) {
			if (!popover) {
				return;
			}
			if (matches) {
				popover.removeAttribute("popover");
			} else {
				popover.setAttribute("popover", "auto");
				popover.hidePopover();
			}
		}

		handleViewportChange(mq.matches);
		mq.addEventListener("change", (e) => handleViewportChange(e.matches));
	}
</script>
