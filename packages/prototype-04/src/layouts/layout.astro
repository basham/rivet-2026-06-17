---
import "@rivet-iu/core/dist/rivet.css";
import "@rivet-iu/core/dist/rivet-icons.css";
import "@rivet-iu/core/dist/rivet-stickers.css";
import Footer from "@rivet-iu/core/src/components/footer/footer.astro";
import Header from "../components/header.astro";
import { menus as _menus, site } from "../const.js";
import { getMenus, getUrl } from "../util.js";

const menus = getMenus(_menus, Astro);
const { label: title } = menus.page;
const root = Astro.url.pathname === getUrl() + "/";
const docTitle = root ? site : [title, site].join(" - ");
const hideTitle = Astro.slots.has("default");
const breadcrumbs = [];

if (menus.page) {
	let parent = menus.page.getParent();
	while (parent) {
		breadcrumbs.unshift(parent);
		parent = parent.getParent();
	}
}

const menu = menus.page.hasChildren ? menus.page : menus.page.getParent();
const menuParent = menu.getParent();

const topMenus = getMenus(_menus, { url: { pathname: "/" } });
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{docTitle}</title>
	</head>
	<body>
		<Header menus={topMenus} />
		<div class="rvt-container">
			<div class="layout-side">
				{
					!root && (
						<rvt-prototype-related-nav>
							<nav aria-labelledby="rvt-prototype-related-nav-heading">
								<div class="rvt-disclosure" data-rvt-disclosure>
									<button
										aria-expanded="false"
										class="rvt-disclosure__toggle"
										data-rvt-disclosure-toggle
									>
										Section menu
									</button>
									<div class="rvt-disclosure__content" data-rvt-disclosure-target hidden>
										<header>
											{menuParent && (
												<div>
													<a
														class="rvt-button rvt-button--medium"
														href={menuParent.url}
													>
														<rvt-icon name="chevron-left"></rvt-icon>
														{menuParent.label}
													</a>
												</div>
											)}
											<h2 id="rvt-prototype-related-nav-heading">
												<a href={menu.url}>{menu.label}</a>
											</h2>
										</header>
										<ul>
											{menu.items.map((item: any) => (
												<li>
													<a
														aria-current={item.current ? "page" : null}
														href={item.url || "#"}
													>
														{item.label}
														{item.hasChildren && (
															<rvt-icon name="chevron-right"></rvt-icon>
														)}
													</a>
													{false && item.current && item.hasChildren && (
														<ul>
															{item.items.map((child: any) => (
																<li>
																	<a href={child.url || "#"}>{child.label}</a>
																</li>
															))}
														</ul>
													)}
												</li>
											))}
										</ul>
									</div>
								</div>
							</nav>
						</rvt-prototype-related-nav>
					)
				}
				{
					!root && (
						<rvt-breadcrumbs>
							<nav aria-label="Breadcrumbs">
								<ol class="rvt-breadcrumbs">
									{breadcrumbs.map((item, i) => (
										<li>
											<a href={item.url}>
												{i === 0 && <span class="rvt-sr-only">Home</span>}
												{i > 0 && item.label}
											</a>
										</li>
									))}
									<li aria-current="page">{title}</li>
								</ol>
							</nav>
						</rvt-breadcrumbs>
					)
				}
				<main id="main-content">
					{
						!hideTitle && (
							<div class="rvt-hero">
								<div class="rvt-hero__body">
									<h1 class="rvt-hero__title">Highlights in {title}</h1>
								</div>
							</div>
						)
					}
					{hideTitle && <h1 class="rvt-sr-only">{title}</h1>}
					{
						menus.page?.articles && (
							<div class="content">
								{menus.page.articles.map((article: any) => (
									<>
										<h2>{article.label}</h2>
										<p>{article.description}</p>
									</>
								))}
							</div>
						)
					}
					<slot />
					{
						menus.page.items && (
							<div>
								<ul class="rvt-card-grid rvt-m-tb-none">
									{menus.page.items.map((item: any) => (
										<li>
											<div class="rvt-card">
												<div class="rvt-card__body">
													<h2 class="rvt-card__title">
														<a href={item.url}>{item.label}</a>
													</h2>
													{item.articles && (
														<div class="rvt-card__content">
															{item.articles.map((article: any) => (
																<p>{article.label}</p>
															))}
														</div>
													)}
												</div>
											</div>
										</li>
									))}
								</ul>
							</div>
						)
					}
				</main>
			</div>
		</div>
		<Footer />
	</body>
</html>

<style>
	.rvt-container:has(> .layout-side) {
		container-type: inline-size;
	}

	.layout-side {
		--border: var(--rvt-size-1) solid var(--rvt-color-theme-ui);
		--gap: var(--rvt-size-40);

		rvt-prototype-related-nav {
			_display: none;
		}

		rvt-breadcrumbs {
			padding-block-end: var(--rvt-size-16);
		}

		main {
			padding-block-end: var(--gap);
		}

		.rvt-hero {
			margin-block-end: var(--gap);
		}
	}

	@container (width > 45rem) {
		.layout-side:has(rvt-prototype-related-nav) {
			display: grid;
			grid-template-columns: 20rem 1fr;
			grid-template-rows: auto 1fr;

			rvt-prototype-related-nav {
				border-block-start: var(--border);
				border-inline-end: var(--border);
				display: block;
				grid-column: 1 / 2;
				grid-row: 1 / -1;
				padding-block: var(--gap);
				padding-inline-end: var(--gap);

				.rvt-disclosure {
					border: none;
					margin-block-end: 0;
					padding: 0;
				}

				.rvt-disclosure__toggle {
					display: none;
				}

				.rvt-disclosure__content {
					display: block;
					margin-block-start: 0;
				}
			}

			&:has(rvt-breadcrumbs) rvt-breadcrumbs,
			&:not(:has(rvt-breadcrumbs)) main {
				border-block-start: var(--border);
				padding-block-start: var(--gap);
			}

			rvt-breadcrumbs {
				grid-column: 2 / 3;
				grid-row: 1 / 2;
				padding-inline-start: var(--gap);
			}

			main {
				grid-column: 2 / 3;
				grid-row: 2 / 3;
				padding-block-end: var(--gap);
				padding-inline-start: var(--gap);
			}
		}
	}

	rvt-prototype-related-nav {
		nav {

			.rvt-disclosure {
				margin-block-end: var(--rvt-size-24);
			}

			.rvt-disclosure__content {
				margin-block-start: var(--rvt-size-24);
				margin-inline-start: 0;
			}

			:is(h2, ul) a {
				color: unset;
				display: block;
				text-decoration: none;

				&:visited {
					color: inherit;
				}

				&:hover {
					color: var(--rvt-color-theme-text-accent);
					text-decoration: underline;
				}

				&[aria-current="page"] {
					color: var(--rvt-color-theme-text-accent);
					font: inherit;
					font-variation-settings: var(--rvt-font-variation-grade);
					text-decoration: underline;
					text-underline-offset: var(--rvt-size-4);
				}
			}

			header {
				margin-block-end: var(--rvt-size-8);

				:is(h2, h3, h4, h5, h6) {

					&:not(:first-child) {
						margin-block-start: var(--rvt-size-32);
					}

					a {
						font: var(--rvt-font-18-bold);
					}
				}
			}

			ul {
				list-style-type: "";
				margin: 0;
				padding: 0;
			}

			ul {
				border-block-start: var(--rvt-size-1) solid var(--rvt-color-theme-ui);

				> li {
					border-block-end: var(--rvt-size-1) solid var(--rvt-color-theme-ui);
					border-block-start: none;
					padding-block: var(--rvt-size-8);

					a {
						display: flex;
						justify-content: space-between;

						rvt-icon {
							padding-block: var(--rvt-size-4);
						}
					}

					li {
						padding-block-start: var(--rvt-size-8);

						> a {
							padding-inline-start: var(--rvt-size-16);
						}
					}
				}
			}
		}
	}

	rvt-breadcrumbs {
		display: block;

		nav {
			display: flex;
		}
	}

	.rvt-hero {
		padding-inline: 0;
	}

	.content {
		h2 {
			font: var(--rvt-font-20-fluid-black);
			margin-block-start: var(--rvt-size-32);
		}
	}

	.rvt-card-grid {
		--gap: clamp(var(--rvt-size-16), 5vw, var(--rvt-size-40));
		grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
	}
</style>

<script>
	import "@rivet-iu/core";
</script>
