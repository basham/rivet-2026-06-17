---
import Layout from "../layouts/layout.astro";

export const title = "Home";
---

<Layout title={title}>
	<div class="rvt-hero rvt-hero--statement rvt-section">
		<div class="rvt-hero__body">
			<h2 class="rvt-hero__title">Dig into history</h2>
			<p class="rvt-hero__teaser">
				Discover major milestones and events over Indiana University's 200-year
				legacy. Be inspired to make your mark for the next generation of
				Hoosiers.
			</p>
		</div>
	</div>
</Layout>
